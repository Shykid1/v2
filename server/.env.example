# ─── Core ────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sanichain_v2?schema=public"
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRY_HOURS=24

# ─── Paystack ────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_WEBHOOK_SECRET=

# ─── Arkesel (WhatsApp + SMS + USSD) ─────────────────────────────────────────
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=SaniChain
ARKESEL_SMS_URL=https://sms.arkesel.com/api/v2/sms/send
ARKESEL_WHATSAPP_URL=https://sms.arkesel.com/api/v2/whatsapp/send
USSD_WEBHOOK_SECRET=

# ─── Sensor HMAC ─────────────────────────────────────────────────────────────
# (per-device keys are stored on Device.hmacKey; this is the dev fallback only)
HMAC_REPLAY_WINDOW_MS=300000

# ─── Climate (flood pre-emption) ─────────────────────────────────────────────
CLIMATE_MOCK_MODE=true
CHIRPS_API_URL=
GLOFAS_API_URL=
GLOFAS_API_KEY=
SPEI_API_URL=
DISTRICTS=East Mamprusi

# ─── GhanaPost GPS (placeholder for now) ─────────────────────────────────────
GHANAPOST_GPS_API_URL=
GHANAPOST_GPS_API_KEY=

# ─── Seed ────────────────────────────────────────────────────────────────────
SEED_ADMIN_PASSWORD=admin1234
